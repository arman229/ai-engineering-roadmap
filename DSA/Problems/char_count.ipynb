      "{'m': 3, 'y': 1, ' ': 4, 'n': 2, 'a': 5, 'e': 1, 'i': 1, 's': 2, 'r': 2, 'h': 1, 'f': 1}\n"
     ]
    }
   ],
   "source": [
    "s = 'my name is arman ashraf'\n",
    "hash_map = {}\n",
    "for i in s:\n",
    "    hash_map[i]= hash_map.get(i,0)+1\n",
    "print(hash_map)\n",
    "# time complexity: O(n)\n",
    "# space complexity: O(n)"
   ]
